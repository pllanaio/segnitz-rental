<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dokument</title>
    <style>
        body { font-family: Arial, sans-serif; }
        .step { margin-bottom: 20px; }
        .element { margin-bottom: 10px; }
        .element-name { font-weight: bold; }
        img.signature { max-width: 200px; height: auto; }
    </style>
</head>
<body>
    {{#each form}}
    <div class="step">
        <h2>Schritt {{step}}</h2>
        {{#each elements}}
        <div class="element">
            <span class="element-name">{{name}}:</span> {{value}}
        </div>
        {{/each}}
    </div>
    {{/each}}
    <img src="{{signaturePath}}" alt="Signatur" class="signature">
</body>
</html>